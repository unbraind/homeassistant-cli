{"ts":"2026-07-16T17:03:28.097Z","author":"codex-root","op":"create","patch":[{"op":"replace","path":"/body","value":"## Discovery\\n\\nVitest reports 95.53% statements, 84.69% branches, 96.36% functions, and 96.1% lines, but vitest.config.ts defines no thresholds. CI therefore uploads coverage without preventing regressions below the documented 90% statement target."},{"op":"add","path":"/metadata/id","value":"hac-u9lg"},{"op":"add","path":"/metadata/title","value":"Enforce documented coverage quality floor"},{"op":"add","path":"/metadata/description","value":"Turn the repository documented coverage target into a failing automated threshold."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["ci","coverage","discovered","quality"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-16T17:03:28.097Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-16T17:03:28.097Z"},{"op":"add","path":"/metadata/deadline","value":"2026-07-18T17:03:28.097Z"},{"op":"add","path":"/metadata/assignee","value":"codex-root"},{"op":"add","path":"/metadata/author","value":"codex-root"},{"op":"add","path":"/metadata/estimated_minutes","value":45},{"op":"add","path":"/metadata/acceptance_criteria","value":"Vitest fails when statements, lines, or functions fall below 90%, or branches fall below 80%; current full coverage run passes; thresholds are documented in configuration history"},{"op":"add","path":"/metadata/parent","value":"hac-gpm3"},{"op":"add","path":"/metadata/reviewer","value":"unbraind"},{"op":"add","path":"/metadata/risk","value":"medium"},{"op":"add","path":"/metadata/confidence","value":100},{"op":"add","path":"/metadata/sprint","value":"2026-07-security"},{"op":"add","path":"/metadata/release","value":"2026.7.16"},{"op":"add","path":"/metadata/dependencies","value":[{"id":"hac-gpm3","kind":"parent","created_at":"2026-07-16T17:03:28.097Z","author":"codex-root"}]},{"op":"add","path":"/metadata/comments","value":[{"created_at":"2026-07-16T17:03:28.097Z","author":"codex-root","text":"Baseline from Vitest 4 coverage: 95.53 statements,84.69 branches,96.36 functions,96.1 lines."}]},{"op":"add","path":"/metadata/notes","value":[{"created_at":"2026-07-16T17:03:28.097Z","author":"codex-root","text":"Use thresholds below the current baseline to avoid unrelated coverage expansion in this security lane while preventing material regressions."}]},{"op":"add","path":"/metadata/learnings","value":[{"created_at":"2026-07-16T17:03:28.097Z","author":"codex-root","text":"Coverage reporting without thresholds is observational,not an enforceable quality gate."}]},{"op":"add","path":"/metadata/files","value":[{"path":"vitest.config.ts","scope":"project","note":"Coverage gate configuration"}]},{"op":"add","path":"/metadata/tests","value":[{"command":"bun run test:coverage","scope":"project","timeout_seconds":1800}]},{"op":"add","path":"/metadata/docs","value":[{"path":"AGENTS.md","scope":"project","note":"Documented 90 percent statement target"}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"0d1140cd55c1332f2bc85f781ee95819deddb21fd3e540294c372663c48010a9","message":"Track discovered missing coverage enforcement"}
