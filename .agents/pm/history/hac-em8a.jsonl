{"ts":"2026-07-16T17:15:52.133Z","author":"codex-root","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/2","value":{"created_at":"2026-07-16T17:15:52.133Z","author":"codex-root","text":"Hosted PR #52 exposed a CI-only commit-audit defect: actions/checkout checks out the synthetic merge ref without a local master branch, so the script's hard-coded master revision failed before inspecting any commits. Fixed the auditor to use origin/..HEAD for pull-request runs and HEAD for complete-history local/push runs; both modes pass locally."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-07-16T17:15:52.133Z"}],"before_hash":"58c61ee34af681cf7613bf4fb8c8b2a4605a5f75ead0176a769a410cbcd2f40c","after_hash":"26d368fd59afdb79cc4feaefc61d1ffc1a9c04c819152e3738488b6fd3ac1d01"}
{"ts":"2026-07-16T17:16:00.597Z","author":"codex-root","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/3","value":{"created_at":"2026-07-16T17:16:00.596Z","author":"codex-root","text":"Correction to the preceding comment: the pull-request range is origin/${GITHUB_BASE_REF}..HEAD; shell interpolation in the command that recorded the earlier comment omitted the variable name from its rendered text."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-07-16T17:16:00.597Z"}],"before_hash":"26d368fd59afdb79cc4feaefc61d1ffc1a9c04c819152e3738488b6fd3ac1d01","after_hash":"3d17555fd40430eff5f112d8287abdd8f2eb1f825fa0876b32052fd17b35202a"}
{"ts":"2026-07-16T17:17:29.429Z","author":"codex-root","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/4","value":{"created_at":"2026-07-16T17:17:29.420Z","author":"codex-root","text":"The corrected hosted log then showed GitHub synthetic merge commit b8ac2ff as the sole non-conforming subject. Added git log --no-merges so generated merge commits are excluded while all authored commits in the base-to-head range remain audited."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-07-16T17:17:29.429Z"}],"before_hash":"3d17555fd40430eff5f112d8287abdd8f2eb1f825fa0876b32052fd17b35202a","after_hash":"90947aa7fbc837f67bdecf53e68ca9ca956f38bc8e4bb507b70c446da1db6be1"}
