{"ts":"2026-07-16T16:54:19.097Z","author":"codex-root","op":"create","patch":[{"op":"replace","path":"/body","value":"## Reproduction\\n\\nOpen Dependabot PR 51 or 50. Every CI matrix job stops at bun install --frozen-lockfile with lockfile had changes. Runner also warns checkout/setup-node v4 use deprecated Node 20 action runtimes."},{"op":"add","path":"/metadata/id","value":"hac-em8a"},{"op":"add","path":"/metadata/title","value":"Restore reproducible Dependabot CI and modernize actions"},{"op":"add","path":"/metadata/description","value":"Fix the shared frozen-lockfile failure and update deprecated GitHub Actions majors."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":["ci","dependabot","github-actions","reproducibility"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-16T16:54:19.097Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-16T16:54:19.097Z"},{"op":"add","path":"/metadata/deadline","value":"2026-07-18T16:54:19.097Z"},{"op":"add","path":"/metadata/assignee","value":"codex-root"},{"op":"add","path":"/metadata/author","value":"codex-root"},{"op":"add","path":"/metadata/estimated_minutes","value":180},{"op":"add","path":"/metadata/acceptance_criteria","value":"fresh frozen Bun install succeeds; workflows use maintained action majors; CI runs dependency audit; workflow syntax and local gates pass"},{"op":"add","path":"/metadata/parent","value":"hac-gpm3"},{"op":"add","path":"/metadata/reviewer","value":"unbraind"},{"op":"add","path":"/metadata/risk","value":"high"},{"op":"add","path":"/metadata/confidence","value":95},{"op":"add","path":"/metadata/sprint","value":"2026-07-security"},{"op":"add","path":"/metadata/release","value":"2026.7.16"},{"op":"add","path":"/metadata/dependencies","value":[{"id":"hac-gpm3","kind":"parent","created_at":"2026-07-16T16:54:19.097Z","author":"codex-root"}]},{"op":"add","path":"/metadata/comments","value":[{"created_at":"2026-07-16T16:54:19.097Z","author":"codex-root","text":"Representative GitHub Actions runs 26775340556 and 26673365486 fail before tests."}]},{"op":"add","path":"/metadata/notes","value":[{"created_at":"2026-07-16T16:54:19.097Z","author":"codex-root","text":"The failure is infrastructure-wide,not specific to Vitest or Commander behavior."}]},{"op":"add","path":"/metadata/learnings","value":[{"created_at":"2026-07-16T16:54:19.097Z","author":"codex-root","text":"Inspect one representative failure before changing source; shared pre-test failures usually belong to the dependency workflow."}]},{"op":"add","path":"/metadata/files","value":[{"path":"bun.lock","scope":"project","note":"Primary implementation surface"}]},{"op":"add","path":"/metadata/tests","value":[{"command":"bun install --frozen-lockfile","scope":"project","timeout_seconds":1800}]},{"op":"add","path":"/metadata/docs","value":[{"path":"docs/RELEASING.md","scope":"project","note":"Relevant project documentation"}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"b7324939e83ab7d6049f0da07726a821669172db2f852da3ec053917c22a7885","message":"Track CI reproducibility and action-runtime remediation"}
