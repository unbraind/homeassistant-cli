{"ts":"2026-07-21T19:13:48.497Z","author":"codex-root","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"hac-ak9g"},{"op":"add","path":"/metadata/title","value":"Make static quality, duplication, security, and pm integrity gates mandatory"},{"op":"add","path":"/metadata/description","value":"Add deterministic Bun scripts and required CI coverage for strict ESLint, docstrings, jscpd, pm validation/health, ShellCheck, Trivy, dependency audit, secret history, CodeQL, coverage upload, build, package smoke, and release verification; document applicability and local parity."},{"op":"add","path":"/metadata/type","value":"Task"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":0},{"op":"add","path":"/metadata/tags","value":["ci","codecov","jscpd","pm","security","static-analysis"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-21T19:13:48.497Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-21T19:13:48.497Z"},{"op":"add","path":"/metadata/assignee","value":"codex-root"},{"op":"add","path":"/metadata/author","value":"codex-root"},{"op":"add","path":"/metadata/estimated_minutes","value":540},{"op":"add","path":"/metadata/acceptance_criteria","value":"One local quality command runs every applicable free gate; CI has required non-optional jobs; unsupported or inapplicable tools such as PSScriptAnalyzer are explicitly documented rather than silently claimed; branch protection requires the new contexts; docs explain exact local and hosted parity"},{"op":"add","path":"/metadata/definition_of_ready","value":"Existing workflows, package scripts, installed tool availability, and free GitHub feature constraints inventoried"},{"op":"add","path":"/metadata/value","value":"A reproducible non-bypassable production quality contract"},{"op":"add","path":"/metadata/impact","value":"Blocks duplication, documentation, type-safety, security, tracker, and coverage regressions before merge"},{"op":"add","path":"/metadata/outcome","value":"Required green quality evidence on every PR and master head"},{"op":"add","path":"/metadata/why_now","value":"Current CI lacks duplication, docstring, ShellCheck, Trivy, and pm integrity jobs and coverage upload is artifact-only"},{"op":"add","path":"/metadata/parent","value":"hac-n0ix"},{"op":"add","path":"/metadata/reviewer","value":"unbraind"},{"op":"add","path":"/metadata/risk","value":"high"},{"op":"add","path":"/metadata/confidence","value":"high"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"67d2063cd9f418a307a842745ad3ab59d55459f475f798969a120d799556b969","message":"Track expanded mandatory free quality gates"}
