  AGENTS.md,project,PM-managed agent guidance
tests[2]:
  - command: pm health --check-only --summary --json
    scope: project
    timeout_seconds: 1800
  - command: pm validate --check-history-drift --strict-exit --json
    scope: project
    timeout_seconds: 300
    pm_context_mode: tracker
