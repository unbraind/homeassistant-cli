# Dependencies
node_modules/

# Build output
dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Environment files - NEVER commit these!
.env
.env.*
*.env

# Home Assistant CLI config - NEVER commit credentials!
.hassio-cli/
hassio-config.json
settings.json
credentials.json

# PM project settings are governance metadata, not Home Assistant credentials.
!.agents/pm/settings.json

# Temporary files
tmp/
temp/
*.tmp

# pm-cli:runtime-cache:start
.agents/pm/runtime/
.agents/pm/search/*
!.agents/pm/search/.gitkeep
.agents/pm/locks/*
!.agents/pm/locks/.gitkeep
# pm-cli:runtime-cache:end
